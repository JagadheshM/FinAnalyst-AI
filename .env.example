# FinAnalyst AI – Environment Variables

# ── LLM ──────────────────────────────────────────────────────────────────────
# Gemini API Key (Required)
GEMINI_API_KEY=your_gemini_api_key_here

# Model to use (default: gemini-2.5-flash for cost efficiency)
GEMINI_MODEL=gemini-2.5-flash

# ── Telegram ──────────────────────────────────────────────────────────────────
# Create a bot via @BotFather and paste the token here
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# The channel ID where reports will be posted (e.g. @YourChannelName or -100xxxxxxxxxx)
TELEGRAM_CHANNEL_ID=your_telegram_channel_id_here

# ── CoinGecko ─────────────────────────────────────────────────────────────────
# Optional: CoinGecko Pro API key (free tier works without this)
COINGECKO_API_KEY=

# ── Scheduler ─────────────────────────────────────────────────────────────────
# Timezone for the scheduler (default: Asia/Kolkata for IST)
SCHEDULER_TIMEZONE=Asia/Kolkata

# Cron times (24h format, IST)
MORNING_BRIEF_TIME=08:45
MIDDAY_UPDATE_TIME=13:00
MARKET_WRAP_TIME=18:30

# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO
